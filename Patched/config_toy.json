{
  "_comment": "Deliberately tiny end-to-end sanity run. It exists so that the SMALLEST possible run is genuinely small: passing only CLI flags with no --config inherits the DEFAULT augmentation (n_positives = n_negatives = 30), which makes a 2-class batch 2*8*61 = 976 rows and will OOM a small box. The ARI this produces is meaningless; you are checking that the pipeline RUNS, not that it works.",

  "data": {
    "data_mode": "synthetic",
    "window_s": 8.0,
    "train_stride_s": 4.0,
    "eval_stride_s": 8.0,
    "split_fractions": [0.6, 0.2, 0.2],
    "synthetic_duration_s": 200.0,
    "synthetic_fs": 50.0,
    "synthetic_n_per_class": [2, 2],
    "augmentation": {
      "fs": 50.0,
      "n_positives": 3,
      "n_negatives": 3,
      "shift_magnitude_s": 1.0,
      "split_method": "warp_bands"
    }
  },
  "backbone": {
    "depth_exponent": 3,
    "width_multiplier": 2.0,
    "block_family": 0,
    "embedding_size": 8,
    "stem_width": 16
  },
  "train": {
    "windows_per_condition": 2,
    "batches_per_epoch": 4,
    "n_seeds": 2,
    "max_epochs": 3,
    "patience": 3
  },
  "search": {
    "depth_exponent_range": [3, 4],
    "width_multiplier_range": [1.5, 2.5],
    "embedding_size_range": [8, 12],
    "n_calls_arch": 4,
    "n_calls_train": 4
  },
  "regularization": {
    "n_calls": 4
  },
  "eval": {
    "kmeans_seed": 0,
    "kmeans_n_init": 10,
    "silhouette_metric": "cosine",
    "pca_components": 2
  },
  "runtime": {
    "seed": 0,
    "device": "cpu",
    "num_workers": 0,
    "torch_threads": 1,
    "out_dir": "out",
    "cache_dir": "cache_toy",
    "experiment_name": "toy"
  }
}
